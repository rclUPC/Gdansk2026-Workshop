// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
FoamFile
{
    version         2;
    format          binary;
    arch            "LSB;label=32;scalar=64";
    class           volScalarField;
    location        "0";
    object          alpha.air;
}

dimensions      [ 0 0 0 0 0 0 0 ];

internalField   uniform 1;

boundaryField
{
    inletMain
    {
        type            fixedValue;
        value           uniform 0;
    }
    outlet
    {
        type            inletOutlet;
        inletValue      uniform 1;
        value           uniform 1;
    }
    inletSecondary
    {
        type            inletOutlet;
        inletValue      uniform 1;
        value           uniform 1;
    }
    wallNozzle1
    {
        type            zeroGradient;
    }
    wallNozzle2
    {
        type            zeroGradient;
    }
    wallDiffuser
    {
        type            zeroGradient;
    }
    front
    {
        type            wedge;
    }
    back
    {
        type            wedge;
    }
    walls
    {
        type            zeroGradient;
    }
}


// ************************************************************************* //
