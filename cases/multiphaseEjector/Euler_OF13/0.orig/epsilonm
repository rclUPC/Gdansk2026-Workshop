FoamFile
{
    version         2;
    format          ascii;
    arch            "LSB;label=32;scalar=64";
    class           volScalarField;
    location        "0";
    object          epsilon.air;
}

dimensions      [ 0 2 -3 0 0 0 0 ];

internalField   uniform 0.1;

boundaryField
{
    inletMain
    {
        type            fixedValue;
	value           $internalField;
    }
    outlet
    {
        type            inletOutlet;
	phi		phim;
	inletValue      $internalField;
        value           $internalField;
    }
    inletSecondary
    {
        type            inletOutlet;
	phi		phim;
        inletValue      $internalField;
        value           $internalField;
    }
    wallNozzle1
    {
        type            epsilonmWallFunction;
        blending        stepwise;
        value           $internalField;
    }
    wallNozzle2
    {
        type            epsilonmWallFunction;
        blending        stepwise;
        value           $internalField;
    }
    wallDiffuser
    {
        type            epsilonmWallFunction;
        blending        stepwise;
        value           $internalField;
    }
    front
    {
        type            wedge;
    }
    back
    {
        type            wedge;
    }
    walls
    {
        type            epsilonmWallFunction;
        blending        stepwise;
        value           $internalField;
    }
}


