boundaryField
{
    inletMain
    {
        type            fixedValue;
        value           uniform 1;
    }
    outlet
    {
        type            inletOutlet;
        inletValue      uniform 0;
        value           uniform 0;
    }
    inletSecondary
    {
        type            inletOutlet;
        inletValue      uniform 0;
        value           uniform 0;
    }
    wallNozzle1
    {
        type            zeroGradient;
    }
    wallNozzle2
    {
        type            zeroGradient;
    }
    wallDiffuser
    {
        type            zeroGradient;
    }
    front
    {
        type            wedge;
    }
    back
    {
        type            wedge;
    }
    walls
    {
        type            zeroGradient;
    }
}


